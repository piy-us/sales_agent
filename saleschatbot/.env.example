# ── Azure AI Foundry / Azure OpenAI ───────────────────────────────────────────
# Your Azure AI Foundry project endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Model deployment names in Azure AI Foundry
# Conversation / Query-rewriter / Context-planner agent model
AZURE_CHAT_DEPLOYMENT=gpt-4.1-mini          # e.g. gpt-4.1-mini or gpt-4o-mini

# Response writer uses a vision-capable model
AZURE_VISION_DEPLOYMENT=gpt-4.1            # vision model e.g. gpt-4.1 / gpt-4o

# ── Azure CosmosDB ─────────────────────────────────────────────────────────────
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-key>
COSMOS_DATABASE=chatbot_db
COSMOS_CONTAINER=conversations
# TTL in seconds for conversation items (default 30 days = 2592000, -1 = no expiry)
COSMOS_TTL=2592000

# ── Azure AI Search (placeholder – not used yet) ───────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=<your-search-key>
AZURE_SEARCH_INDEX=enterprise-docs

# ── Azure Blob Storage (placeholder – not used yet) ────────────────────────────
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_CONTAINER=enterprise-images

# ── App settings ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_HISTORY_TURNS=10          # how many past turns to load for context
MAX_REWRITE_LOOPS=3           # safety cap on query-rewriter → planner loops
RELEVANCE_THRESHOLD=0.70      # minimum score from RAG to consider context "enough"
